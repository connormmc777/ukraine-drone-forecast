# Copy to .env for docker-compose or supply via Helm values in K8s.
# NEVER commit .env with real values.

# Public URL — used in freshness banners and share links
BASE_URL=http://localhost:8501

# Streamlit runtime tuning
STREAMLIT_SERVER_HEADLESS=true
STREAMLIT_SERVER_ADDRESS=0.0.0.0
STREAMLIT_SERVER_PORT=8501
STREAMLIT_BROWSER_GATHER_USAGE_STATS=false

# Optional: Telethon (for deep-history Telegram backfill beyond preview window)
# Get free credentials at https://my.telegram.org/apps
TELETHON_API_ID=
TELETHON_API_HASH=

# Optional: ACLED API for cross-source validation
# Requires researcher-tier approval — see docs
ACLED_EMAIL=
ACLED_PASSWORD=

# Cron / autostart schedule (in the container)
SYNC_INTERVAL_SECONDS=7200
